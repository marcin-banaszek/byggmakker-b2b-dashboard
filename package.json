{
  "name": "kesko-design-system",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-brand design system components",
  "main": "index.js",
  "workspaces": [
    "b2b-dashboard",
    "docs-site",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev:b2b": "cd \"b2b-dashboard\" && npm run dev",
    "dev:docs": "cd \"docs-site\" && npm run dev",
    "build:b2b": "cd \"b2b-dashboard\" && npm run build",
    "build:docs": "cd \"docs-site\" && npm run build",
    "lint:b2b": "cd \"b2b-dashboard\" && npm run lint",
    "lint:docs": "cd \"docs-site\" && npm run lint"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.4.5"
  }
}
